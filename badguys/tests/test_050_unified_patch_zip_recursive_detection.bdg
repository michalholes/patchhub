[meta]
makes_commit = false
is_guard = false

[subjects.recursive_file]
relpath = "docs/badguys_batch1/unified_recursive.txt"

[[asset]]
id = "zip"
kind = "patch_zip_manifest"

[[asset.entry]]
name = "patch_entry"
kind = "git_patch_text"
subject = "recursive_file"
zip_name = "subdir/inner.patch"
content = """ok
"""

[[step]]
op = "RUN_RUNNER"
input_asset = "zip"
