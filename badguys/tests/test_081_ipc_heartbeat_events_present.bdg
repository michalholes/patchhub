[meta]
makes_commit = false
is_guard = false

[subjects.heartbeat_marker]
relpath = "docs/badguys_batch3/ipc_heartbeat_marker.txt"

[[asset]]
id = "patch"
kind = "git_patch_text"
subject = "heartbeat_marker"
content = """ipc heartbeat marker
"""

[[step]]
op = "RUN_RUNNER"
input_asset = "patch"

[[step]]
op = "READ_TEXT_FILE"
scope = "artifacts"
relpath = "runner.ipc.step0.jsonl"
