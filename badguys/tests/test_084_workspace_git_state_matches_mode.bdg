[meta]
makes_commit = false
is_guard = false

[subjects.workspace_fail]
relpath = "scripts/badguys_batch3/workspace_compile_fail.py"

[[asset]]
id = "patch"
kind = "git_patch_text"
subject = "workspace_fail"
content = """def broken(:
"""

[[step]]
op = "RUN_RUNNER"
input_asset = "patch"

[[step]]
op = "GIT_STATUS_PORCELAIN"
scope = "root"

[[step]]
op = "GIT_STATUS_PORCELAIN"
scope = "workspace"
